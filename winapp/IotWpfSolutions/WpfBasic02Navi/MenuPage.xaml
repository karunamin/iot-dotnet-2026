<Page x:Class="WpfBasic02Navi.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="520" d:DesignWidth="890"
      Title="MenuPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button x:Name="BtnMenu01" Content="SimpleControls Page" Margin="10,10,5,10" Width="160" Click="BtnMenu01_Click"/>
            <Button x:Name="BtnMenu02" Content="SimpleControls Page" Margin="5,10,5,10" Width="150" Click="BtnMenu02_Click"/>
            <Button Content="Page03" Margin="5,10,5,10" Width="150"/>
            <Button Content="Page04" Margin="5,10,5,10" Width="150"/>
            <Button Content="Page05" Margin="5,10,10,10" Width="150"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Button Content="Page06" Margin="10,10,536,76" RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="-0.689"/>
                        <RotateTransform/>
                        <TranslateTransform X="-0.463"/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
            <Button Content="Page07" Margin="269,10,266,75"/>
            <Button Content="Page08" Margin="539,10,10,75"/>
            <Button Content="Page09" Margin="10,80,237,10"/>
            <Button Content="Page10" Margin="568,80,10,10" />
        </Grid >

        <DockPanel Grid.Row="2">
            <Button Content="Page11" DockPanel.Dock="Top" />
            <Button Content="Page12" DockPanel.Dock="Left"/>
            <Button Content="Page13" DockPanel.Dock="Right"/>
            <Button Content="Page14" DockPanel.Dock="Bottom"/>
            <Button Content="Page15" />
        </DockPanel>
    </Grid>
</Page>
