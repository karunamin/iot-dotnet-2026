<Window x:Class="WpfTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="도서 관리 시스템"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Text="도서 관리 시스템"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="5"/>

        <!-- 도서 목록 -->
        <DataGrid x:Name="GrdBooks"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  Margin="5"
                  IsReadOnly="True"
                  MouseDoubleClick="GrdBooks_MouseDoubleClick"/>

        <!-- 입력 영역 -->
        <Border Grid.Row="2"
                Margin="5"
                Padding="15"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#DDDDDD">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 도서번호 -->
                <TextBlock Text="도서번호"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TxtBookIdx"
                         Grid.Column="1"
                         Margin="5"
                         IsReadOnly="True"/>

                <!-- 저자 -->
                <TextBlock Text="저자"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TxtAuthor"
                         Grid.Column="3"
                         Margin="5"/>

                <!-- 도서명 -->
                <TextBlock Text="도서명"
                           Grid.Row="1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TxtBookName"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="5"/>

                <!-- ISBN -->
                <TextBlock Text="ISBN"
                           Grid.Row="1"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TxtIsbn"
                         Grid.Row="1"
                         Grid.Column="3"
                         Margin="5"/>

                <!-- 출판일 -->
                <TextBlock Text="출판일"
                           Grid.Row="2"
                           VerticalAlignment="Center"/>

                <DatePicker x:Name="DtpReleaseDt"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5"/>

                <!-- 장르 -->
                <TextBlock Text="장르"
                           Grid.Row="2"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="CboDivCode"
                          Grid.Row="2"
                          Grid.Column="3"
                          Margin="5"/>

                <!-- 가격 -->
                <TextBlock Text="가격"
                           Grid.Row="3"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TxtPrice"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="5"/>

                <!-- 버튼 -->
                <StackPanel Grid.Row="3"
                            Grid.Column="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="BtnSave"
                            Content="저장"
                            Width="100"
                            Margin="5"
                            Click="BtnSave_Click"/>

                    <Button x:Name="BtnDelete"
                            Content="삭제"
                            Width="100"
                            Margin="5"
                            Click="BtnDelete_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- 상태바 -->
        <StatusBar Grid.Row="3">

            <StatusBarItem Content="BookRentalShop Books v1.0"/>

            <Separator/>

            <StatusBarItem>
                <TextBlock x:Name="SbiResMsg"/>
            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>