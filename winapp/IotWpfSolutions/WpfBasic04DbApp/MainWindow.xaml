<mah:MetroWindow
    x:Class="WpfBasic03Navi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:WpfBasic03Navi"
    mc:Ignorable="d"
    Title="Books Database" Height="450" Width="800">
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <iconPacks:PackIconGameIcons Kind="Abstract035" Margin="10,7,0,0" Foreground="White" />            
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>
    <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        
        <!-- DataGrid d:ItemsSource="{d:SampleData ItemCount=5}"/-->
        <DataGrid x:Name="GrdBooks" Margin="5"
          AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="순번" Binding="{Binding book_idx}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="저자" Binding="{Binding author}" />
                <DataGridTextColumn Header="장르코드" Binding="{Binding div_code}" Visibility="Hidden" />
                <DataGridTextColumn Header="책장르" Binding="{Binding div_name}" />
                <DataGridTextColumn Header="책이름" Binding="{Binding book_name}" />
                <DataGridTextColumn Header="출판일" Binding="{Binding release_dt, StringFormat='yyyy-MM-dd'}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="Margin" Value="5,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ISBN" Binding="{Binding isbn}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="Margin" Value="5,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="책가격" Binding="{Binding price, StringFormat={}{0:N0}원}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        
        <GroupBox Grid.Column="1" Margin="5" Header="책 상세">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <mah:NumericUpDown x:Name="NudBookIdx" Grid.Row="0" Minimum="0" IsReadOnly="True" Margin="5"/>
                <TextBox 
                    x:Name="TxtAuthor" Grid.Row="1" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="저자"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    />
                <ComboBox
                    x:Name="CboDivCode"
                    Grid.Row="2"
                    Margin="5"
                    mah:TextBoxHelper.Watermark="책장르"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    />
                <TextBox x:Name="TxtBookName" Grid.Row="3" Margin="5"
                         mah:TextBoxHelper.AutoWatermark="True"
                         mah:TextBoxHelper.Watermark="책제목"
                         mah:TextBoxHelper.ClearTextButton="True"
                         mah:TextBoxHelper.UseFloatingWatermark="True"
                         />
                <DatePicker x:Name="DtpReleaseDt" Grid.Row="4" Margin="5"/>
                <TextBox x:Name="TxtIsbn" Grid.Row="5" Margin="5"/>
                <TextBox x:Name="TxtPrice" Grid.Row="6" Margin="5"/>

                
                
                <StackPanel Grid.Row="7" Orientation="Horizontal">
                    <Button x:Name="BtnNew" Width="100" Content="신규" Margin="5" 
        Style="{StaticResource MahApps.Styles.Button.Dialogs.Accent}"/>
                    <Button x:Name="BtnSave" Width="100" Content="저장" Margin="5"/>
                    <Button x:Name="BtnDelete" Width="100" Content="삭제" Margin="5"/>                    
                </StackPanel>
            </Grid>
        </GroupBox>
        <StatusBar x:Name="StbWindow" Grid.Row="1" Grid.Column="2" />

    </Grid>
</mah:MetroWindow>

    