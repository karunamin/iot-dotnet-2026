<mah:MetroWindow x:Class="WpfProductAdmin.ProductCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfProductAdmin"
        mc:Ignorable="d"
        Title="상품 등록" Height="330" Width="420">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Height Auto : 내부에 들어가는 컨트롤의 높이 따라 변경 -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="상품명" />
        <TextBox x:Name="TxtProductName" Grid.Row="1" Height="32" Margin="0,5" />

        <TextBlock Grid.Row="2" Text="카테고리" />
        <TextBox x:Name="TxtCategory" Grid.Row="3" Height="32" Margin="0,5" />

        <StackPanel Grid.Row="4">
            <TextBlock Text="가격" />
            <mah:NumericUpDown x:Name="NudPrice" Height="32" Margin="0,5" Minimum="1000" />

            <TextBlock Text="재고" />
            <mah:NumericUpDown x:Name="NudStock" Height="32" Margin="0,5" Minimum="0" />
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="저장" Width="90" Height="35" Margin="0,0,8,0" Click="BtnSave_Click" />
            <Button x:Name="BtnCancel" Content="취소" Width="90" Height="35" Click="BtnCancel_Click" />
        </StackPanel>

    </Grid>
</mah:MetroWindow>