<mah:MetroWindow x:Class="WpfToyProject.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Product"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <StackPanel>

            <TextBox x:Name="TxtName" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtCategory" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtPrice" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtStock" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="저장"
                        Width="80"
                        Click="BtnSave_Click"/>

                <Button Content="취소"
                        Width="80"
                        Margin="10,0,0,0"
                        Click="BtnCancel_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</mah:MetroWindow>